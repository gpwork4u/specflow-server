# === Required ===
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === LLM Provider ===
# Provider: "openai" (default, covers Ollama/vLLM/Groq/Together/Mistral/DeepSeek)
#           "anthropic" (Claude)
#           "azure" (Azure OpenAI)
LLM_PROVIDER=openai

# --- OpenAI / Ollama / vLLM / compatible ---
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5-coder:32b

# --- OpenAI Official ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o

# --- Anthropic (Claude) ---
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=claude-sonnet-4-20250514

# --- Azure OpenAI ---
# LLM_PROVIDER=azure
# LLM_BASE_URL=https://your-resource.openai.azure.com
# LLM_API_KEY=your-azure-api-key
# LLM_MODEL=gpt-4o
# AZURE_DEPLOYMENT=your-deployment-name
# AZURE_API_VERSION=2024-06-01

# --- Groq ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=llama-3.1-70b-versatile

# --- DeepSeek ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=deepseek-coder

# === Sandbox ===
# SANDBOX_MEMORY=2g
# SANDBOX_CPUS=2
# SANDBOX_TIMEOUT_SECS=600
# DOCKER_NETWORK=specflow-server_specflow

# === Security ===
# GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
